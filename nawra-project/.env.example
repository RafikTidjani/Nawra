# ═══════════════════════════════════════════════
# VELORA — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS COMMITTER .env.local
# ═══════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────
# Dashboard : https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── STRIPE ──────────────────────────────────────
# Dashboard : https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── RESEND (emails) ─────────────────────────────
# Dashboard : https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contact@velorabeauty.fr
RESEND_ADMIN_EMAIL=admin@velorabeauty.fr

# ── APP ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mot de passe pour accéder à /admin (MVP simple)
ADMIN_SECRET=velora_admin_2026
